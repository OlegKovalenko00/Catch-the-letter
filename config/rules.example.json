{
  "rules": [
    {
      "id": "hse_forms",
      "name": "HSE forms and surveys",
      "enabled": true,
      "priority": 100,
      "match": {
        "mode": "any",
        "conditions": [
          {
            "field": "subject",
            "op": "regex_i",
            "value": "(–Њ–њ—А–Њ—Б|–∞–љ–Ї–µ—В–∞|—Д–Њ—А–Љ–∞|–Њ—Ж–µ–љ–Ї–∞|—А–µ–≥–Є—Б—В—А–∞—Ж–Є—П|–Ј–∞–њ–Њ–ї–љ–Є—В–µ|survey|form|questionnaire)"
          },
          {
            "field": "body_text",
            "op": "regex_i",
            "value": "(–Њ–њ—А–Њ—Б|–∞–љ–Ї–µ—В–∞|—Д–Њ—А–Љ–∞|–Њ—Ж–µ–љ–Ї–∞|—А–µ–≥–Є—Б—В—А–∞—Ж–Є—П|–Ј–∞–њ–Њ–ї–љ–Є—В–µ|survey|form|questionnaire)"
          },
          {
            "field": "links.domain",
            "op": "domain_in",
            "value": [
              "portal.hse.ru",
              "forms.yandex.ru",
              "docs.google.com",
              "forms.gle",
              "forms.office.com",
              "forms.microsoft.com",
              "lms.hse.ru",
              "smartlms.hse.ru"
            ]
          }
        ]
      },
      "actions": [
        {
          "type": "classify"
        },
        {
          "type": "detect_form"
        },
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Э–∞–є–і–µ–љ–∞ –њ–Њ—В–µ–љ—Ж–Є–∞–ї—М–љ–∞—П —Д–Њ—А–Љ–∞: {{subject}}"
        }
      ]
    },
    {
      "id": "important_hse_notifications_subject",
      "name": "Important HSE notifications by subject",
      "enabled": true,
      "priority": 70,
      "match": {
        "mode": "all",
        "conditions": [
          {
            "field": "from",
            "op": "contains_i",
            "value": "@hse.ru"
          },
          {
            "field": "subject",
            "op": "regex_i",
            "value": "(–≤–∞–ґ–љ–Њ|—Б—А–Њ—З–љ–Њ|–і–µ–і–ї–∞–є–љ|—Н–Ї–Ј–∞–Љ–µ–љ|–Њ—Ж–µ–љ–Є–≤–∞–љ–Є–µ|lms|smartlms)"
          }
        ]
      },
      "actions": [
        {
          "type": "classify"
        },
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Т–∞–ґ–љ–Њ–µ –њ–Є—Б—М–Љ–Њ –Т–®–≠: {{subject}}"
        }
      ]
    },
    {
      "id": "important_hse_notifications_body",
      "name": "Important HSE notifications by body",
      "enabled": true,
      "priority": 69,
      "match": {
        "mode": "all",
        "conditions": [
          {
            "field": "from",
            "op": "contains_i",
            "value": "@hse.ru"
          },
          {
            "field": "body_text",
            "op": "regex_i",
            "value": "(–≤–∞–ґ–љ–Њ|—Б—А–Њ—З–љ–Њ|–і–µ–і–ї–∞–є–љ|—Н–Ї–Ј–∞–Љ–µ–љ|–Њ—Ж–µ–љ–Є–≤–∞–љ–Є–µ|lms|smartlms)"
          }
        ]
      },
      "actions": [
        {
          "type": "classify"
        },
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Т–∞–ґ–љ–Њ–µ –њ–Є—Б—М–Љ–Њ –Т–®–≠: {{subject}}"
        }
      ]
    },
    {
      "id": "important_notifications",
      "name": "Generic important notifications",
      "enabled": true,
      "priority": 50,
      "match": {
        "mode": "any",
        "conditions": [
          {
            "field": "subject",
            "op": "regex_i",
            "value": "(–і–µ–і–ї–∞–є–љ|–≤–∞–ґ–љ–Њ|—Б—А–Њ—З–љ–Њ|–љ–∞–њ–Њ–Љ–Є–љ–∞–љ–Є–µ|deadline|important)"
          }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Т–∞–ґ–љ–Њ–µ –њ–Є—Б—М–Љ–Њ: {{subject}}"
        },
        {
          "type": "notify",
          "channel": "console",
          "text": "–Т–∞–ґ–љ–Њ: {{from}} / {{subject}}"
        }
      ]
    },
    {
      "id": "education_forms",
      "name": "Education forms",
      "enabled": true,
      "priority": 80,
      "match": {
        "mode": "any",
        "conditions": [
          {
            "field": "links.domain",
            "op": "domain_in",
            "value": [
              "forms.yandex.ru",
              "docs.google.com",
              "forms.gle",
              "forms.office.com",
              "forms.microsoft.com"
            ]
          },
          {
            "field": "body_text",
            "op": "regex_i",
            "value": "(–∞–љ–Ї–µ—В–∞|–Њ–њ—А–Њ—Б|survey|questionnaire|registration form)"
          }
        ]
      },
      "actions": [
        {
          "type": "classify"
        },
        {
          "type": "detect_form"
        },
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Э–∞–є–і–µ–љ–∞ —Д–Њ—А–Љ–∞: {{subject}}"
        }
      ]
    },
    {
      "id": "auth_required_forms",
      "name": "Auth required LMS-like forms",
      "enabled": true,
      "priority": 90,
      "match": {
        "mode": "any",
        "conditions": [
          {
            "field": "links.domain",
            "op": "domain_in",
            "value": [
              "lms.hse.ru",
              "smartlms.hse.ru",
              "id.hse.ru"
            ]
          },
          {
            "field": "body_text",
            "op": "regex_i",
            "value": "(lms|smartlms|course evaluation|–Њ—Ж–µ–љ–Є–≤–∞–љ–Є–µ|–∞–≤—В–Њ—А–Є–Ј–∞—Ж|–≤–Њ–є–і–Є—В–µ)"
          }
        ]
      },
      "actions": [
        {
          "type": "classify"
        },
        {
          "type": "detect_form"
        },
        {
          "type": "notify",
          "channel": "telegram",
          "text": "–Э–∞–є–і–µ–љ–∞ —Д–Њ—А–Љ–∞ —Б –≤–Њ–Ј–Љ–Њ–ґ–љ–Њ–є –∞–≤—В–Њ—А–Є–Ј–∞—Ж–Є–µ–є: {{subject}}"
        }
      ]
    }
  ]
}
