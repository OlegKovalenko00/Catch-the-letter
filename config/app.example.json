{
  "app": {
    "poll_interval_seconds": 60,
    "events_limit": 200,
    "timezone": "Europe/Moscow",
    "demo_mode": false,
    "log_level": "info"
  },
  "mailboxes": [
    {
      "id": "main_yandex",
      "provider": "yandex",
      "email": "user@yandex.ru",
      "imap_host": "imap.yandex.com",
      "imap_port": 993,
      "imap_ssl": true,
      "auth_method": "password",
      "username_env": "IMAP_USERNAME",
      "password_env": "IMAP_PASSWORD",
      "folder": "INBOX",
      "checkpoint_mode": "uid"
    }
  ],
  "telegram": {
    "enabled": true,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_id_env": "TELEGRAM_CHAT_ID",
    "proxy_url_env": "TELEGRAM_PROXY_URL",
    "poll_updates": true,
    "poll_interval_seconds": 2
  },
  "web": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 8080,
    "auth_token_env": "WEB_AUTH_TOKEN"
  },
  "browser_worker": {
    "enabled": true,
    "endpoint": "http://browser-worker:8090",
    "timeout_seconds": 60
  },
  "form_providers": {
    "prefer_provider_api": true,
    "browser_fallback_for_known_providers": false
  },
  "yandex_forms_api": {
    "enabled": true,
    "base_url": "https://api.forms.yandex.net/v1",
    "oauth_token_env": "YANDEX_FORMS_OAUTH_TOKEN",
    "org_id_env": "YANDEX_FORMS_ORG_ID",
    "cloud_org_id_env": "YANDEX_FORMS_CLOUD_ORG_ID",
    "form_map_file": "config/yandex_forms.map.json",
    "dry_run": false,
    "allow_browser_fallback": false,
    "timeout_seconds": 60
  },
  "google_forms_api": {
    "enabled": true,
    "credentials_json_env": "GOOGLE_APPLICATION_CREDENTIALS",
    "oauth_token_env": "GOOGLE_FORMS_OAUTH_TOKEN",
    "form_map_file": "config/google_forms.map.json",
    "dry_run": false,
    "allow_browser_fallback": false,
    "timeout_seconds": 60
  },
  "llm": {
    "enabled": true,
    "provider": "ollama",
    "endpoint": "http://ollama:11434/api/chat",
    "endpoint_env": "LLM_ENDPOINT",
    "model": "qwen3:4b",
    "model_env": "LLM_MODEL",
    "privacy_mode": "safe",
    "timeout_seconds": 300,
    "auto_fallback_to_noop": true,
    "healthcheck_timeout_seconds": 30,
    "startup_probe": true,
    "min_memory_gb": 6,
    "recommended_memory_gb": 8,
    "auto_pull": true
  },
  "auth": {
    "enabled": true,
    "allow_credentials_via_telegram": false,
    "allow_credentials_via_web": true,
    "remember_credentials": false,
    "credentials_storage": "memory",
    "two_factor_via_telegram": true,
    "two_factor_via_web": true
  },
  "security": {
    "mode": "open",
    "allow_private_networks": false,
    "auto_submit": false,
    "require_confirmation_before_submit": true,
    "allowed_domains": [],
    "blocked_domains": []
  },
  "profile_file": "/app/config/profile.json",
  "rules_file": "/app/config/rules.json",
  "storage": {
    "sqlite_path": "/app/data/state.db"
  },
  "mail_processing": {
    "classify_unmatched_with_llm": true,
    "notify_important_without_rules": true,
    "store_all_fetched": true,
    "store_body_for_important": true,
    "max_body_chars_to_store": 20000,
    "max_body_chars_to_llm": 6000,
    "notify_min_importance": "high",
    "llm_confidence_threshold": 0.65,
    "fallback_keyword_importance": true,
    "mark_seen_after_success": false
  },
  "attachments": {
    "enabled": true,
    "fetch_on_demand": true,
    "telegram_send_enabled": true,
    "max_telegram_size_mb": 20,
    "max_download_size_mb": 50,
    "dangerous_extensions": ["exe", "bat", "cmd", "scr", "js", "vbs", "jar", "msi", "ps1", "sh", "apk"],
    "warn_extensions": ["zip", "rar", "7z", "docm", "xlsm"],
    "retention_hours": 24
  },
  "max_retries": 3,
  "backoff_base_ms": 500,
  "backoff_max_ms": 8000
}
