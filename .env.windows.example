# Windows 10/11 + Docker Desktop environment template
# Copy to .env and fill in your credentials

IMAP_USERNAME=
IMAP_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Windows Docker Desktop:
# If Telegram works directly, keep empty.
# If your proxy/VPN exposes HTTP proxy on Windows localhost:10809:
# TELEGRAM_PROXY_URL=http://host.docker.internal:10809
TELEGRAM_PROXY_URL=

WEB_AUTH_TOKEN=

GMAIL_USERNAME=
GMAIL_PASSWORD=

EVENTS_LIMIT=200

# LLM / Ollama
LLM_ENABLED=true
LLM_MODEL=qwen3:4b

# Recommended on Windows PC with native Ollama installed:
# 1. Install Ollama for Windows
# 2. Run: ollama pull qwen3:4b
# 3. Keep Ollama running on Windows
# 4. Set LLM_ENDPOINT to host.docker.internal:
LLM_ENDPOINT=http://host.docker.internal:11434/api/chat

# If using Docker Ollama service instead, uncomment:
# LLM_ENDPOINT=http://ollama:11434/api/chat

LLM_TIMEOUT_SECONDS=300
LLM_HEALTHCHECK_TIMEOUT_SECONDS=30
LLM_AUTO_FALLBACK=true
LLM_AUTO_PULL=true
LLM_MIN_MEMORY_GB=6
