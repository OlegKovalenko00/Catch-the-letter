# Optional Telegram proxy.
# Linux VPN mode (docker-compose.vpn.yml, network_mode: host):
#   TELEGRAM_PROXY_URL=http://127.0.0.1:10809
# Windows Docker Desktop (if proxy on Windows localhost):
#   TELEGRAM_PROXY_URL=http://host.docker.internal:10809
# Ordinary Docker bridge without proxy:
#   TELEGRAM_PROXY_URL=
TELEGRAM_PROXY_URL=

WEB_AUTH_TOKEN=

GMAIL_USERNAME=
GMAIL_PASSWORD=

# Local LLM / Ollama.
# If Ollama or the model is unavailable, the app falls back to rule-based Noop mapping.
LLM_ENABLED=true
LLM_MODEL=qwen3:4b

# Choose LLM_ENDPOINT based on your setup:
# 1. Docker Ollama service (default, docker-compose.yml --profile llm):
#    LLM_ENDPOINT=http://ollama:11434/api/chat
# 2. Linux VPN mode (docker-compose.vpn.yml, Ollama on host):
#    LLM_ENDPOINT=http://127.0.0.1:11434/api/chat
# 3. Windows Docker Desktop (native Ollama on Windows):
#    LLM_ENDPOINT=http://host.docker.internal:11434/api/chat
# 4. Windows Docker Desktop (Docker Ollama service):
#    LLM_ENDPOINT=http://ollama:11434/api/chat

LLM_ENDPOINT=http://ollama:11434/api/chat

LLM_TIMEOUT_SECONDS=300
LLM_HEALTHCHECK_TIMEOUT_SECONDS=30
LLM_AUTO_FALLBACK=true

# Pull model automatically in ollama-init service. Set false to pull manually.
LLM_AUTO_PULL=true
LLM_MIN_MEMORY_GB=6
