IMAP_USERNAME=
IMAP_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Telegram proxy.
# Use this if Telegram is unavailable from Docker network.
# For docker-compose.vpn.yml with app network_mode: host:
# TELEGRAM_PROXY_URL=http://127.0.0.1:10809
# For ordinary Docker bridge, if your proxy listens on 0.0.0.0:
# TELEGRAM_PROXY_URL=http://host.docker.internal:10809
TELEGRAM_PROXY_URL=

WEB_AUTH_TOKEN=

GMAIL_USERNAME=
GMAIL_PASSWORD=

EVENTS_LIMIT=200
